  "keyFeatures": [
    "Query compiler that generates optimized query plans for Prisma Client",
    "Schema engine for database migrations and introspection",
    "Prisma Schema Language (PSL) parser and validator",
    "Driver adapters for executing queries through JavaScript database drivers",
    "SQL query builder with support for PostgreSQL, MySQL, SQLite, SQL Server, and CockroachDB",
    "LSP features and formatting via prisma-fmt",
    "Comprehensive test suite with connector test kit"
  ],
  "publicApiSurface": [
    "query-compiler (library): Query planning and compilation",
    "query-structure (library): AST and type system for queries",
    "schema-core (library): Migration and introspection core logic",
    "psl-core (library): Prisma Schema Language parser and validator",
    "schema-engine (binary): CLI for migrations and introspection",
    "prisma-fmt (binary): Formatter and language server",
    "query-compiler-wasm: WebAssembly build for query compiler",
    "driver-adapters: TypeScript adapters for database drivers",
    "sql-schema-describer: Database schema introspection",
    "quaint: SQL connection and query abstraction"
  ]
}
